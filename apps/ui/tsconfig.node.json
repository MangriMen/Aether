{
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    // TS 6 required
    "types": ["node"],
    // Vite + Tauri
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "include": ["vite.config.ts", "bump.config.ts"]
}
