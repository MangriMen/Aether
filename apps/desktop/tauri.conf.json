{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aether",
  "mainBinaryName": "Aether",
  "version": "0.10.0",
  "identifier": "aether.launcher",
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost aether-asset: https://asset.localhost http://* https://*",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/cache/assets/*",
          "$APPCONFIG/cache/assets/*",
          "$CONFIG/cache/assets/*"
        ]
      }
    }
  },
  "build": {
    "beforeDevCommand": "bun x turbo run dev --filter @aether/frontend",
    "beforeBuildCommand": "bun x turbo run build --filter @aether/frontend",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4REQ5MDlFOEUzN0I3NDUKUldSRnR6ZU9ucERkR09aREE5ckQzNW9TOVB5d2NTMVdVdFpJdElncXdObC9pRFJ2OEQvend0dkQK",
      "endpoints": [
        "https://github.com/MangriMen/aether/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
