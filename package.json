{
  "name": "@aether/monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "aether:bump": "bun --filter @aether/frontend run bump",
    "build": "turbo run build --continue",
    "clean": "turbo run clean && bun x rimraf .turbo && cargo clean",
    "desktop:build": "turbo run build --filter=@aether/desktop",
    "desktop:dev": "turbo run dev --filter=@aether/desktop",
    "frontend:build": "turbo run build --filter=@aether/frontend",
    "frontend:dev": "turbo run dev --filter=@aether/frontend",
    "lint": "turbo run lintt --continue",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260626.1",
    "lefthook": "^2.1.9",
    "turbo": "latest",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=24"
  }
}
