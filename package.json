{
  "name": "@aether/monorepo",
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "app:dev": "turbo run tauri --filter=@aether/app -- dev",
    "lint": "turbo run lint",
    "update-bindings": "cd apps/desktop/src-tauri && cargo update-bindings",
    "postinstall": "bun run update-bindings"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "lefthook": "^2.1.5",
    "turbo": "latest",
    "typescript": "^6.0.2"
  }
}
