{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PluginManifest",
  "description": "Root configuration for an Aether plugin.",
  "type": "object",
  "properties": {
    "api": {
      "description": "Integration with the host application API.",
      "$ref": "#/$defs/ApiConfig"
    },
    "load": {
      "description": "Defines how the plugin code should be loaded and executed.",
      "$ref": "#/$defs/LoadConfig"
    },
    "metadata": {
      "description": "Information about the plugin identity.",
      "$ref": "#/$defs/PluginMetadata"
    },
    "runtime": {
      "description": "Sandbox and security restrictions for the plugin.",
      "$ref": "#/$defs/RuntimeConfig"
    }
  },
  "additionalProperties": false,
  "required": [
    "metadata",
    "runtime",
    "load",
    "api"
  ],
  "$defs": {
    "ApiConfig": {
      "type": "object",
      "properties": {
        "features": {
          "description": "List of optional host features requested by the plugin.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "version": {
          "description": "Required API version range (SemVer requirement).",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "version"
      ]
    },
    "LoadConfig": {
      "oneOf": [
        {
          "description": "Use WebAssembly (Extism) for a secure, cross-platform sandbox.",
          "type": "object",
          "properties": {
            "file": {
              "description": "Path to the .wasm file relative to the plugin root.",
              "type": "string"
            },
            "memoryLimit": {
              "description": "Maximum memory (in bytes) the plugin is allowed to allocate.",
              "type": [
                "integer",
                "null"
              ],
              "format": "uint",
              "default": null,
              "minimum": 0
            },
            "type": {
              "type": "string",
              "const": "extism"
            }
          },
          "required": [
            "type",
            "file"
          ]
        },
        {
          "description": "Load a native shared library (.dll, .so, .dylib). Less secure, but faster.",
          "type": "object",
          "properties": {
            "libPath": {
              "description": "Path to the dynamic library file relative to the plugin root.",
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "native"
            }
          },
          "required": [
            "type",
            "libPath"
          ]
        }
      ]
    },
    "PathMapping": {
      "description": "A mapping between a path on the host and a virtual path in the plugin.\nFormat: [host_path, virtual_path]",
      "type": "array",
      "maxItems": 2,
      "minItems": 2,
      "prefixItems": [
        {
          "description": "Path on the host disk.",
          "type": "string"
        },
        {
          "description": "Virtual path inside the plugin sandbox.",
          "type": "string"
        }
      ]
    },
    "PluginMetadata": {
      "type": "object",
      "properties": {
        "authors": {
          "description": "List of plugin authors.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "description": {
          "description": "Short summary of the plugin's purpose.",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "description": "Unique identifier for the plugin (lowercase, kebab-case).",
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "license": {
          "description": "License under which the plugin is distributed.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Readable name of the plugin.",
          "type": "string"
        },
        "version": {
          "description": "Semantic version of the plugin.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version"
      ]
    },
    "RuntimeConfig": {
      "type": "object",
      "properties": {
        "allowedHosts": {
          "description": "List of domains or IP addresses the plugin is allowed to connect to.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "allowedPaths": {
          "description": "Filesystem access restrictions. Maps host paths to plugin-internal paths.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/PathMapping"
          }
        }
      },
      "additionalProperties": false
    }
  }
}