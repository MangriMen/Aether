{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapabilityMetadataDto",
  "type": "object",
  "properties": {
    "description": {
      "description": "Optional detailed description of what this capability does.",
      "type": [
        "string",
        "null"
      ]
    },
    "icon": {
      "description": "Optional icon file name or URL for the UI.",
      "type": [
        "string",
        "null"
      ]
    },
    "id": {
      "description": "Identifier for the capability (lowercase, kebab/underscore allowed).",
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "name": {
      "description": "Display name of the capability.",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "id",
    "name"
  ]
}